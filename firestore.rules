rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: only the user themselves can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Listings: authenticated users can read active listings; farmers can create and update their own
    match /listings/{listing} {
      allow read: if resource.data.status == 'active' ||
                   (request.auth != null && resource.data.farmer_id == request.auth.uid);
      allow create: if request.auth != null &&
                     request.resource.data.farmer_id == request.auth.uid &&
                     request.resource.data.status == 'active';
      allow update: if request.auth != null &&
                     resource.data.farmer_id == request.auth.uid;
      allow delete: false;
    }

    // Bids: drivers can read their own bids; farmers can read bids on their listings
    match /bids/{bid} {
      allow read: if request.auth != null &&
                   (resource.data.driver_id == request.auth.uid ||
                    (exists(/databases/$(database)/documents/listings/$(resource.data.listing_id)) &&
                     get(/databases/$(database)/documents/listings/$(resource.data.listing_id)).data.farmer_id == request.auth.uid));
      allow create: if request.auth != null &&
                     request.resource.data.driver_id == request.auth.uid;
      allow update: if request.auth != null &&
                     (resource.data.driver_id == request.auth.uid ||
                      (exists(/databases/$(database)/documents/listings/$(resource.data.listing_id)) &&
                       get(/databases/$(database)/documents/listings/$(resource.data.listing_id)).data.farmer_id == request.auth.uid));
    }

    // Transactions: only involved parties can read; creation via backend only
    match /transactions/{txn} {
      allow read: if request.auth != null &&
                   (resource.data.buyer_id == request.auth.uid ||
                    resource.data.driver_id == request.auth.uid ||
                    (exists(/databases/$(database)/documents/listings/$(resource.data.listing_id)) &&
                     get(/databases/$(database)/documents/listings/$(resource.data.listing_id)).data.farmer_id == request.auth.uid));
      allow write: if false; // only backend can create via firebase-admin
    }

    // Driver locations: only the driver can write, any authenticated user can read (farmer tracking)
    match /driver_locations/{driverId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }
  }
}